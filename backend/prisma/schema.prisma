generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id String @id @default(uuid())

  name           String
  email          String   @unique
  barrierxUserId String   @unique
  hubspotOwnerId String?  @unique
  tenantSlug     String
  isAuth         Boolean  @default(false)
  isEnabled      Boolean  @default(true)
  role           UserRole @default(USER)

  // Onboarding & profile fields
  phone               String?
  businessType        String?
  softwareCategory    String?
  averageSalesCycle   String?
  averageDealSize     String?
  onboardingCompleted Boolean @default(false)
  selectedPlan        String?
  stripeCustomerId    String? @unique

  // Settings profile fields
  firstName String?
  lastName  String?
  country   String?
  gender    Gender?
  avatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription   Subscription?
  refreshTokens  RefreshToken[]
  socialLinks    UserSocialLink[]
  integrations   UserIntegration[]

  // ⚡ Composite index for scheduler query optimization
  @@index([isAuth, isEnabled])
}

// User's social profile URLs (1:many)
model UserSocialLink {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform SocialPlatform @default(OTHER)
  url      String
  order    Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, order])
}

// User's connected third-party integrations (1:many, unique per provider)
model UserIntegration {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider IntegrationProvider
  status   IntegrationStatus   @default(DISCONNECTED)

  externalAccountId String?
  scopes            String[]
  metadata          Json?

  // Credentials (encrypted at rest; null while mocked)
  accessTokenEnc  String?   @db.Text
  refreshTokenEnc String?   @db.Text
  tokenExpiresAt  DateTime?

  connectedAt    DateTime?
  disconnectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Subscription {
  id String @id @default(uuid())

  // Link to user via barrierxUserId
  barrierxUserId String @unique
  user           User   @relation(fields: [barrierxUserId], references: [barrierxUserId])

  // Plan details
  planId   String
  planName String
  interval BillingInterval @default(MONTHLY)

  // Stripe IDs (populated when real Stripe is integrated)
  stripeSubscriptionId String? @unique
  stripeCustomerId     String?
  stripePriceId        String?
  stripePaymentIntentId String?

  // Status
  status SubscriptionStatus @default(INCOMPLETE)

  // Period tracking
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialStart         DateTime?
  trialEnd           DateTime?

  // Cancellation
  cancelAtPeriodEnd Boolean   @default(false)
  canceledAt        DateTime?

  // Mock payment tracking
  mockSessionId       String? @unique
  mockPaymentVerified Boolean @default(false)
  mockPaymentMethod   String?
  amount              Int?
  currency            String  @default("usd")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([planId])
}

// ============================================
// LOGGING MODELS
// ============================================

// Activity Log - Master table for all backend activities
model ActivityLog {
  id String @id @default(uuid())

  // Core fields
  activityType ActivityType
  status       Status       @default(PENDING)

  // User Context (standardized)
  userId         String? // AgentX database UUID
  userName       String? // User display name
  userEmail      String? // User email (stable field for filtering)
  barrierxUserId String? // BarrierX platform UUID
  hubspotOwnerId String? // HubSpot CRM owner ID

  // Tenant Context
  tenantSlug String? // BarrierX tenant slug
  tenantName String? // BarrierX tenant display name

  // Related entities
  dealId         String?
  dealName       String?
  meetingId      String?
  meetingTitle   String?
  conversationId String?
  callSid        String?

  // Metadata
  metadata     Json?
  errorMessage String?
  errorStack   String? @db.Text

  // Performance tracking
  duration Int?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId])
  @@index([userEmail])
  @@index([activityType])
  @@index([status])
  @@index([dealId])
  @@index([conversationId])
  @@index([createdAt])
  @@index([tenantSlug])
  // ⚡ Composite indexes for common query patterns
  @@index([userId, createdAt(sort: Desc)])
  @@index([userEmail, createdAt(sort: Desc)])
  @@index([dealId, activityType])
  @@index([status, createdAt(sort: Desc)])
}

// Call Log - Detailed call tracking
model CallLog {
  id String @id @default(uuid())

  // Call identification
  conversationId String?       @unique
  callSid        String?
  callType       CallType
  callDirection  CallDirection @default(OUTBOUND)

  // User Context (standardized)
  userId         String // AgentX database UUID (or legacy mixed IDs)
  userName       String // User display name
  userEmail      String // User email (stable field for filtering)
  barrierxUserId String? // BarrierX platform UUID
  hubspotOwnerId String? // HubSpot CRM owner ID

  // Tenant Context
  tenantSlug String? // BarrierX tenant slug
  tenantName String? // BarrierX tenant display name

  // Deal context
  dealId       String
  dealName     String
  // Meeting context — optional because NL workflow calls are not tied to a
  // meeting. Pre/post-meeting calls still populate these.
  meetingId    String?
  meetingTitle String?

  // Call details
  phoneNumber String
  ownerName   String?
  agentId     String?

  // Trigger context
  triggerSource TriggerSource
  triggerUserId String?

  // Status & Timing
  status      CallStatus @default(INITIATED)
  initiatedAt DateTime   @default(now())
  answeredAt  DateTime?
  completedAt DateTime?
  duration    Int?

  // Call outcome
  callSuccessful    Boolean?
  failureReason     String?
  transcriptSummary String?  @db.Text

  // Retry tracking
  retryAttempt Int     @default(1)
  maxRetries   Int     @default(3)
  parentCallId String?

  // Metadata
  dynamicVariables Json?
  webhookData      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userEmail])
  @@index([dealId])
  @@index([callType])
  @@index([status])
  @@index([conversationId])
  @@index([initiatedAt])
  @@index([phoneNumber])
  @@index([tenantSlug])
  // ⚡ Composite indexes for analytics and webhook queries
  @@index([phoneNumber, callType, initiatedAt(sort: Desc)])
  @@index([userId, initiatedAt(sort: Desc)])
  @@index([userEmail, initiatedAt(sort: Desc)])
  @@index([status, initiatedAt])
  @@index([callType, status])
  @@index([tenantSlug, initiatedAt(sort: Desc)])
}

// CRM Action Log - Notes, Meetings, Contacts created via AI
model CrmActionLog {
  id String @id @default(uuid())

  // Action type
  actionType CrmActionType

  // User Context (standardized)
  userId         String? // AgentX database UUID
  userName       String? // User display name
  userEmail      String? // User email (stable field for filtering)
  barrierxUserId String? // BarrierX platform UUID
  hubspotOwnerId String? // HubSpot CRM owner ID
  ownerId        String // Legacy: HubSpot owner ID (kept for backward compatibility)

  // Context
  conversationId String?
  dealId         String?
  tenantSlug     String
  tenantName     String? // BarrierX tenant display name

  // Action details
  entityId String?
  title    String?
  body     String? @db.Text

  // Status
  status       Status  @default(PENDING)
  errorMessage String?

  // Metadata
  metadata Json?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([actionType])
  @@index([status])
  @@index([dealId])
  @@index([conversationId])
  @@index([createdAt])
  @@index([userEmail])
  @@index([userId])
  @@index([ownerId])
  @@index([tenantSlug])
}

// Webhook Log - All incoming webhooks
model WebhookLog {
  id String @id @default(uuid())

  // Webhook identification
  webhookType WebhookType
  eventType   String

  // Context
  conversationId String?
  agentId        String?

  // Tenant Context
  tenantSlug     String? // BarrierX tenant slug
  tenantName     String? // BarrierX tenant display name
  barrierxUserId String? // BarrierX platform UUID
  hubspotOwnerId String? // HubSpot CRM owner ID

  // Status
  status         Status  @default(SUCCESS)
  processingTime Int?
  errorMessage   String?

  // Data
  payload  Json
  response Json?

  // Headers (for security audit)
  signature      String?
  signatureValid Boolean?

  createdAt DateTime @default(now())

  @@index([webhookType])
  @@index([eventType])
  @@index([conversationId])
  @@index([createdAt])
  // ⚡ Composite index for webhook queries
  @@index([conversationId, eventType, createdAt])
}

// Scheduler Log - Track automated runs
model SchedulerLog {
  id String @id @default(uuid())

  // Run details
  jobType SchedulerJobType
  status  Status           @default(RUNNING)

  // Tenant Context
  tenantSlug     String? // BarrierX tenant slug
  tenantName     String? // BarrierX tenant display name
  barrierxUserId String? // BarrierX platform UUID
  hubspotOwnerId String? // HubSpot CRM owner ID

  // Results
  totalUsers         Int?
  preCallsTriggered  Int?
  postCallsTriggered Int?
  errorsCount        Int?

  // Performance
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  duration    Int?

  // Details
  errorMessage String?
  metadata     Json?

  @@index([jobType])
  @@index([status])
  @@index([startedAt])
}

// Error Log - Centralized error tracking
model ErrorLog {
  id String @id @default(uuid())

  // Error context
  errorType ErrorType
  severity  Severity
  source    String

  // Error details
  message String
  stack   String? @db.Text
  code    String?

  // User Context (standardized)
  userId         String? // AgentX database UUID
  userName       String? // User display name
  userEmail      String? // User email (stable field for filtering)
  barrierxUserId String? // BarrierX platform UUID
  hubspotOwnerId String? // HubSpot CRM owner ID

  // Tenant Context
  tenantSlug String? // BarrierX tenant slug
  tenantName String? // BarrierX tenant display name

  // Other Context
  dealId   String?
  endpoint String?
  method   String?

  // Request/Response
  requestData  Json?
  responseData Json?

  // Resolution
  isResolved Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  resolution String?   @db.Text

  createdAt DateTime @default(now())

  @@index([errorType])
  @@index([severity])
  @@index([isResolved])
  @@index([createdAt])
  @@index([userEmail])
  @@index([userId])
  @@index([tenantSlug])
  // ⚡ Composite index for dashboard critical errors query
  @@index([severity, isResolved, createdAt(sort: Desc)])
  @@index([errorType, createdAt(sort: Desc)])
}

// SMS Log - Track SMS notifications sent to deal owners
model SmsLog {
  id String @id @default(uuid())

  // SMS Details
  messageSid  String? // Twilio message SID
  status      SmsStatus @default(QUEUED)
  toPhone     String
  fromPhone   String
  messageBody String?   @db.Text

  // User identifiers (standardized)
  userId         String // AgentX database user ID
  barrierxUserId String? // BarrierX user ID
  hubspotOwnerId String? // HubSpot owner ID

  // Tenant Context
  tenantSlug String? // BarrierX tenant slug
  tenantName String? // BarrierX tenant display name

  // User info
  userName  String?
  userEmail String?
  ownerName String?

  // Deal & Meeting context
  dealId       String?
  dealName     String?
  meetingId    String?
  meetingTitle String?

  // Error tracking
  errorMessage    String?
  twilioErrorCode String?

  // Trigger source
  triggerSource TriggerSource @default(SCHEDULED)

  // Timestamps
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userEmail])
  @@index([status])
  @@index([createdAt])
  @@index([meetingId])
  @@index([tenantSlug])
  // ⚡ Composite indexes for common queries
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([tenantSlug, createdAt(sort: Desc)])
}

// ============================================
// BARRIERX INFO GATHERING
// ============================================

// Store structured responses from BarrierX info gathering calls
model BarrierXInfoGathering {
  id String @id @default(uuid())

  // Gathering Type - what kind of info gathering call
  gatheringType GatheringType @default(ZERO_SCORE)

  // Deal Context
  dealId      String
  dealName    String
  tenantSlug  String
  tenantName  String?
  companyName String?

  // Owner who was called
  ownerName      String
  ownerEmail     String
  ownerPhone     String
  hubspotOwnerId String?
  barrierxUserId String? // BarrierX platform UUID

  // Call tracking
  conversationId String? @unique
  callSid        String?

  // Call status
  status BarrierXInfoStatus @default(PENDING)

  // ============================================
  // ZERO SCORE FIELDS
  // ============================================
  quantifiedPainPoints String? @db.Text // Q1: What are the quantified pain points?
  championInfo         String? @db.Text // Q2: Who is the champion?
  economicBuyerInfo    String? @db.Text // Q3: Who is the economic buyer?

  // ============================================
  // LOST DEAL FIELDS (3 Questions)
  // ============================================
  lossReason     String? @db.Text // Q1: What was the primary reason this deal was lost?
  competitorName String? // Q2: Who was the deal lost to?
  lessonsLearned String? @db.Text // Q3: What could we improve for next time?

  // ============================================
  // INACTIVITY FIELDS (3 Questions)
  // ============================================
  inactivityStatus    String? @db.Text // Q1: What's the current status of this deal?
  inactivityBlockers  String? @db.Text // Q2: Are there any blockers or challenges?
  inactivityNextSteps String? @db.Text // Q3: What are the next steps you're planning?

  // Call metadata
  callDuration      Int?
  transcriptSummary String? @db.Text
  rawTranscript     Json?

  // Timestamps
  initiatedAt DateTime  @default(now())
  answeredAt  DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([tenantSlug])
  @@index([ownerEmail])
  @@index([status])
  @@index([gatheringType])
  @@index([initiatedAt])
}

enum GatheringType {
  ZERO_SCORE // Deals with no BarrierX score
  LOST_DEAL // Deals marked as Lost
  INACTIVITY // Deals with no activity for 2 weeks
}

enum BarrierXInfoStatus {
  PENDING // Call initiated but not answered
  IN_PROGRESS // Call in progress
  COMPLETED // Call completed with answers
  FAILED // Call failed (no answer, busy, etc.)
  SKIPPED // Manually skipped
}

// ============================================
// SERVICE API KEY MANAGEMENT
// ============================================

// External Service Registration
model Service {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  apiKeys ServiceApiKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// API Keys for external services
model ServiceApiKey {
  id String @id @default(uuid())

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  name      String // e.g., "Production Key", "Staging Key"
  keyHash   String @unique // SHA-256 hash of the API key
  keyPrefix String // First 12 chars for identification (e.g., "sk_live_abc1")

  scopes String[] // e.g., ["logs:read", "logs:read:batch"]

  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  createdBy String? // Admin email who created the key

  @@index([keyHash])
  @@index([serviceId])
  @@index([isActive])
}

