# ── Database ────────────────────────────────────────────────────────
DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"
DIRECT_URL="postgresql://<user>:<password>@<host>/<db>"

# ── App ─────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET="change-me-in-production"

# Bypass admin guards in development (ignored in production)
DISABLE_ADMIN_GUARD=false

# ── CORS / Frontend ────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
FRONTEND_URL="http://localhost:3000"

# ── BarrierX ────────────────────────────────────────────────────────
BARRIERX_BASE_URL="https://platform.barrierx.ai"
BARRIERX_API_KEY=""

# ── ElevenLabs ──────────────────────────────────────────────────────
ELEVENLABS_KEY=""
ELEVENLABS_PRE_AGENT_ID=""
ELEVENLABS_POST_AGENT_ID=""
ELEVENLABS_INFO_GATHERING_AGENT_ID=""
ELEVENLABS_NL_WORKFLOW_AGENT_ID=""
ELEVENLABS_PHONE_NUMBER_ID=""
ELEVENLABS_WEBHOOK_SECRET=""

# ── Call Retry ──────────────────────────────────────────────────────
ENABLE_CALL_RETRY=false
CALL_RETRY_MAX_ATTEMPTS=3
CALL_RETRY_INTERVAL_MS=120000

# ── Automation ──────────────────────────────────────────────────────
AUTOMATION_MODE=authenticated
TARGET_TENANT_SLUGS=""
DEAL_UPDATE_WINDOW_DAYS=60
DEAL_PIPELINES=""

# ── Redis ───────────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=""

# ── Twilio ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""
TWILIO_SMS_ENABLED=false
SMS_NOTIFICATION_MINUTES_BEFORE=30

# ── DeepSeek LLM ───────────────────────────────────────────────────
DEEPSEEK_API_KEY=""

# ── Slack ───────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=""
SLACK_ENABLED=false

# ── API Docs (Swagger) ─────────────────────────────────────────────
DOCS_USERNAME="admin"
DOCS_PASSWORD=""

# ── Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_BUSINESS_MONTHLY=""
STRIPE_PRICE_BUSINESS_ANNUAL=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_ANNUAL=""
